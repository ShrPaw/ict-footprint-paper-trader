# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your chat ID (send /start to your bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=your_chat_id_here

# Hyperliquid Testnet (for live paper trading with real orders)
# 1. Go to https://app.hyperliquid-testnet.xyz/
# 2. Connect or create a wallet
# 3. Get testnet USDC from the faucet
# 4. Export your private key from the wallet
HYPERLIQUID_PRIVATE_KEY=0x_your_private_key_here

# TradingView Webhook Secret (optional)
WEBHOOK_SECRET=paper-trader-local
