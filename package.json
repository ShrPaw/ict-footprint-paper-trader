{
  "name": "ict-footprint-paper-trader",
  "version": "1.2.0",
  "description": "ICT + Footprint paper trading engine with regime-adaptive strategies for MEXC perps",
  "type": "module",
  "scripts": {
    "server": "node webhook-server/server.js",
    "dashboard": "node dashboard/server.js",
    "backtest": "node engine/backtest.js",
    "backtest:verbose": "node engine/backtest.js --verbose",
    "backtest:eth": "node engine/backtest.js --exchange binance --symbol ETH/USDT --from 2025-01-01 --to 2025-05-01",
    "backtest:sol": "node engine/backtest.js --exchange binance --symbol SOL/USDT --from 2025-01-01 --to 2025-05-01",
    "backtest:btc": "node engine/backtest.js --exchange binance --symbol BTC/USDT --from 2025-01-01 --to 2025-05-01",
    "backtest:xrp": "node engine/backtest.js --exchange binance --symbol XRP/USDT --from 2025-01-01 --to 2025-05-01"
  },
  "dependencies": {
    "ccxt": "^4.4.0",
    "ws": "^8.18.0",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.10"
  }
}
