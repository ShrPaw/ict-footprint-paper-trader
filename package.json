{
  "name": "ict-footprint-paper-trader",
  "version": "1.2.0",
  "description": "ICT + Footprint paper trading engine with regime-adaptive strategies for MEXC perps",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env engine/main.js",
    "backtest": "node engine/backtest.js",
    "backtest:verbose": "node engine/backtest.js --verbose",
    "backtest:eth": "node engine/backtest.js --exchange binance --symbol ETH/USDT:USDT --from 2022-01-01 --to 2026-03-31",
    "backtest:sol": "node engine/backtest.js --exchange binance --symbol SOL/USDT:USDT --from 2022-01-01 --to 2026-03-31",
    "backtest:btc": "node engine/backtest.js --exchange binance --symbol BTC/USDT:USDT --from 2022-01-01 --to 2026-03-31",
    "backtest:xrp": "node engine/backtest.js --exchange binance --symbol XRP/USDT:USDT --from 2022-01-01 --to 2026-03-31",
    "backtest:all": "npm run backtest:eth && npm run backtest:sol && npm run backtest:btc && npm run backtest:xrp",
    "dashboard": "node dashboard/server.js",
    "bot:eth": "node --env-file=.env bots/eth/bot.js",
    "bot:sol": "node --env-file=.env bots/sol/bot.js",
    "bot:btc": "node --env-file=.env bots/btc/bot.js",
    "bot:xrp": "node --env-file=.env bots/xrp/bot.js",
    "bots:all": "node --env-file=.env bots/eth/bot.js & node --env-file=.env bots/sol/bot.js & node --env-file=.env bots/btc/bot.js & node --env-file=.env bots/xrp/bot.js & wait",
    "live:eth": "node --env-file=.env bots/live/eth.js",
    "live:sol": "node --env-file=.env bots/live/sol.js",
    "live:btc": "node --env-file=.env bots/live/btc.js",
    "live:xrp": "node --env-file=.env bots/live/xrp.js",
    "live:all": "node --env-file=.env bots/live/eth.js & node --env-file=.env bots/live/sol.js & node --env-file=.env bots/live/btc.js & node --env-file=.env bots/live/xrp.js & wait",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop all",
    "pm2:logs": "pm2 logs",
    "backtest:eth:funding": "node engine/backtest.js --exchange binance --symbol ETH/USDT:USDT --from 2022-01-01 --to 2026-03-31 --funding 0.0001",
    "backtest:sol:funding": "node engine/backtest.js --exchange binance --symbol SOL/USDT:USDT --from 2022-01-01 --to 2026-03-31 --funding 0.0001",
    "backtest:btc:funding": "node engine/backtest.js --exchange binance --symbol BTC/USDT:USDT --from 2022-01-01 --to 2026-03-31 --funding 0.0001",
    "backtest:xrp:funding": "node engine/backtest.js --exchange binance --symbol XRP/USDT:USDT --from 2022-01-01 --to 2026-03-31 --funding 0.0001",
    "live:binance:eth": "node --env-file=.env bots/live/binance/eth.js",
    "live:binance:sol": "node --env-file=.env bots/live/binance/sol.js",
    "live:binance:btc": "node --env-file=.env bots/live/binance/btc.js",
    "live:binance:xrp": "node --env-file=.env bots/live/binance/xrp.js",
    "live:binance:all": "node --env-file=.env bots/live/binance/eth.js & node --env-file=.env bots/live/binance/sol.js & node --env-file=.env bots/live/binance/btc.js & node --env-file=.env bots/live/binance/xrp.js & wait"
  },
  "dependencies": {
    "ccxt": "^4.4.0",
    "ws": "^8.18.0",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.10"
  }
}
